# graphify ignore — same syntax as .gitignore; merged after .gitignore, only ever excludes more.
# Icon size variants are pixel-identical duplicates: keep one representative per set,
# skip the rest (each PNG costs a separate vision-extraction pass and spawns duplicate concept nodes).

Sources/Assets.xcassets/AppIcon.appiconset/*.png
!Sources/Assets.xcassets/AppIcon.appiconset/icon_256.png

Sources/Assets.xcassets/MenuBarIcon.imageset/*.png
!Sources/Assets.xcassets/MenuBarIcon.imageset/menubar_36.png

Sources/Assets.xcassets/MenuBarIconUpdate.imageset/*.png
!Sources/Assets.xcassets/MenuBarIconUpdate.imageset/menubar_update_36.png

docs/glosso-icon.png
